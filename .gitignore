# ===========================
# SKILLOR — .gitignore
# ===========================

# ---- Environment & Secrets ----
.env
.env.*
*.env
.env.local
.env.production

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl

# ---- Virtual environments ----
venv/
.venv/
env/
ENV/

# ---- Logs ----
*.log
pipeline.log

# ---- Generated Output (videos, audio, images) ----
output/*
!output/.gitkeep

# ---- Fallback image pool (generated by scripts/generate_fallback_images.py) ----
assets/fallback_images/*
!assets/fallback_images/.gitkeep

# ---- OS files ----
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ---- IDE / Editor ----
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ---- Temporary files ----
*.tmp
*.bak
*.pyc
*.pyo

# ---- Chatterbox / Kokoro model cache (downloaded at runtime) ----
.cache/
models/
*.ckpt
*.pt
*.bin

# ---- Playwright browser cache ----
pw-browsers/
.playwright/

# ---- Node (if any tooling added later) ----
node_modules/
package-lock.json

