# ===========================
# SKILLOR — .gitignore
# ===========================

# ---- Environment & Secrets ----
.env
.env.*
*.env
.env.local
.env.production

# ---- Auth / token artifacts (CRITICAL — never commit these) ----
# scripts/get_refresh_token.py historically wrote oauth_backup.json into the
# repo root. One careless `git add .` would publish a YouTube refresh token
# (= full account takeover). These patterns close that trap.
oauth_backup.json
client_secrets*.json
client_secret*.json
token*.json
*.token
secrets*.json
**/oauth_backup.json

# Private voice-clone reference — keep locally, never on a public repo.
assets/voice_reference.wav

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl

# ---- Virtual environments ----
venv/
.venv/
env/
ENV/

# ---- Logs ----
*.log
pipeline.log

# ---- Generated Output (videos, audio, images) ----
output/*
!output/.gitkeep

# ---- Fallback image pool (generated by scripts/generate_fallback_images.py) ----
assets/fallback_images/*
!assets/fallback_images/.gitkeep

# ---- OS files ----
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ---- IDE / Editor ----
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ---- Temporary files ----
*.tmp
*.bak
*.pyc
*.pyo

# ---- Chatterbox / Kokoro model cache (downloaded at runtime) ----
.cache/
models/
*.ckpt
*.pt
*.bin

# ---- Playwright browser cache ----
pw-browsers/
.playwright/

# ---- Node (if any tooling added later) ----
node_modules/
package-lock.json

